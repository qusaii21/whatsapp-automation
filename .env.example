# ============================================================
# Environment Variables Template
# Copy to .env.local — NEVER commit .env.local
# ============================================================

# ---- Supabase -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---- WhatsApp Cloud API -------------------------------------
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
# Used to verify webhook signatures (HMAC-SHA256)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# ---- Meta Lead Ads ------------------------------------------
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_meta_webhook_verify_token

# ---- AI Providers -------------------------------------------
# Set ACTIVE_AI_PROVIDER to 'gemini' or 'openai'
ACTIVE_AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
# Fallback threshold: if primary fails, switch to secondary
AI_FALLBACK_ENABLED=true

# ---- App Config ---------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# ---- Rate Limiting ------------------------------------------
# Max WhatsApp messages per second (Meta limit is 80/s per WABA)
WHATSAPP_SEND_RATE_LIMIT=20
